# Resend (outbound + inbound)
RESEND_API_KEY=re_...
RESEND_FROM=Helpdesk <support@seudominio.com>
RESEND_INBOUND_DOMAIN=seudominio.com
RESEND_WEBHOOK_SECRET=whsec_...

# Cloudflare Turnstile (anti-spam embed form)
TURNSTILE_SECRET=
# Front: copiar para .env (gitignored) com prefixo VITE_
VITE_TURNSTILE_SITE_KEY=

# Embed
EMBED_BASE_URL=https://app.seudominio.com
VITE_POCKETBASE_URL=https://app.seudominio.com
